# =============================================================
# Конфигурация Retake Info System
# Скопируйте этот файл как .env и заполните под своё развёртывание.
# =============================================================

# ---------- БАЗА ДАННЫХ ----------
# URL подключения в формате SQLAlchemy.
# По умолчанию — локальная SQLite в корне проекта.
# Для PostgreSQL пример:
#   postgresql+psycopg2://user:password@localhost:5432/retake_db
DATABASE_URL=sqlite:///./retake.db


# ---------- СЕТЕВЫЕ ПАРАМЕТРЫ ----------
# Адрес для биндинга сервера.
#   0.0.0.0   — слушать все интерфейсы (нужно для доступа извне).
#   127.0.0.1 — только локальные подключения (для разработки).
SERVER_HOST=0.0.0.0

# Порт сервера. Стандарт для веб-сервисов на FastAPI — 8000.
SERVER_PORT=8000


# ---------- ПУБЛИЧНЫЙ ДОМЕН ----------
# Заполните этот блок ПОСЛЕ привязки своего домена к ПК.
# Например, если у вас домен retake.example.com:

# Публичное имя сервиса (без http:// и без слеша на конце).
PUBLIC_DOMAIN=

# Разрешённые хосты через запятую. Звёздочка «*» — любые хосты
# (только для разработки!). На production:
#   localhost,127.0.0.1,retake.example.com
ALLOWED_HOSTS=*


# ---------- URL ВНЕШНИХ РЕСУРСОВ УНИВЕРСИТЕТА ----------
# Страница основной экзаменационной сессии (первичная попытка).
UNIVERSITY_SESSION_URL=https://misis.ru/students/session/

# Страница ликвидации задолженностей (вторичная пересдача / комиссия).
# Если пусто — автозагрузка по этому источнику отключена.
UNIVERSITY_RETAKES_URL=
