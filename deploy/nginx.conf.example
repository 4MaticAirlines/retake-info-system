# =============================================================
# Заготовка конфигурации nginx для Retake Info System.
#
# Использование:
#   1. Замените YOUR_DOMAIN на ваш домен (например, retake.example.com).
#   2. Скопируйте этот файл в /etc/nginx/sites-available/retake
#   3. Создайте симлинк: sudo ln -s /etc/nginx/sites-available/retake \
#                                   /etc/nginx/sites-enabled/
#   4. Проверьте конфиг: sudo nginx -t
#   5. Перезапустите: sudo systemctl reload nginx
#   6. Получите TLS-сертификат через certbot (см. README, шаг 4).
# =============================================================

# HTTP — перенаправление на HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name YOUR_DOMAIN;

    # Можно временно (на этапе настройки) убрать этот блок
    # и оставить только HTTPS-блок ниже.
    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS — основной блок
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name YOUR_DOMAIN;

    # Пути к сертификатам после получения через certbot
    ssl_certificate     /etc/letsencrypt/live/YOUR_DOMAIN/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/YOUR_DOMAIN/privkey.pem;

    # Базовая безопасность TLS
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # Лимит размера загружаемого файла (для Excel и PDF)
    client_max_body_size 25M;

    # Прокси на uvicorn
    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Таймауты (модель может обучаться 20-30 секунд)
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }

    # Кеширование статики (CSS, картинки)
    location /static/ {
        proxy_pass http://127.0.0.1:8000;
        expires 7d;
        add_header Cache-Control "public, immutable";
    }
}
